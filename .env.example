# Backend environment variables
# Copy this to .env and fill in values (never commit .env to git)

# Comma-separated list of allowed frontend origins
# Example: https://docmark.up.railway.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Frontend environment variables (set in Railway dashboard)
# URL of the deployed backend service — no trailing slash
# Example: https://docmark-backend.up.railway.app
BACKEND_URL=http://localhost:8000
